{
  "name": "langgraph-vue3-chatbot",
  "version": "0.1.23",
  "private": false,
  "type": "module",
  "main": "./dist-lib/index.js",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izerui/langgraph-vue3-chatbot.git"
  },
  "files": [
    "dist-lib"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:lib": "vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.lib.json",
    "check:lib": "node ./scripts/check-lib.mjs",
    "prepublishOnly": "npm version patch --no-git-tag-version && pnpm check:lib"
  },
  "dependencies": {
    "@langchain/langgraph-sdk": "^1.6.5",
    "@vueuse/core": "^14.2.1",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "markstream-vue": "0.0.8",
    "mermaid": "^11.12.3",
    "motion-v": "^2.0.0",
    "nanoid": "^5.1.6",
    "reka-ui": "^2.9.1",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.5.0",
    "vue-stick-to-bottom": "^1.0.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue-tsc": "^2.0.6"
  }
}
